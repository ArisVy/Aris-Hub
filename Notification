-- Hiệu ứng trượt vào (Slide In)
local targetPos = UDim2.new(1, -300, 0.7, 0)
local tweenIn = TweenService:Create(frame, TweenInfo.new(0.5, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Position = targetPos})
tweenIn:Play()

-- Tự động biến mất sau 5 giây
task.delay(5, function()
    local tweenOut = TweenService:Create(frame, TweenInfo.new(0.5, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {Position = UDim2.new(1, 20, 0.7, 0)})
    tweenOut:Play()
    tweenOut.Completed:Connect(function()
        gui:Destroy()
    end)
end)
