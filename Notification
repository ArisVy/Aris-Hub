local TweenService = game:GetService("TweenService")
local PlayerGui = game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui")

-- Xóa thông báo cũ nếu đang chạy lại script
if PlayerGui:FindFirstChild("RobloxCustomNotify") then
    PlayerGui.RobloxCustomNotify:Destroy()
end

local gui = Instance.new("ScreenGui")
gui.Name = "RobloxCustomNotify"
gui.Parent = PlayerGui
gui.ResetOnSpawn = false

-- Khung nền (Giống Notification mặc định)
local frame = Instance.new("Frame")
frame.Name = "NotifyFrame"
frame.Size = UDim2.new(0, 280, 0, 70)
