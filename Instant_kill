-- Xoay gradient
RunService.RenderStepped:Connect(function()
    local rot = (tick() * 180) % 360
    pillGradient.Rotation = rot
    menuGradient.Rotation = rot
    smallGradient.Rotation = rot
    langGradient.Rotation = rot
    scrollGradient.Rotation = rot
end)

-- Mở menu
btnText.MouseButton1Click:Connect(function()
    if not screenGuiMenu.Enabled then
        screenGuiMenu.Enabled = true
        pillButton.Visible = false
        mainFrame.Size = UDim2.new(0, 0, 0, 0)
        TweenService:Create(mainFrame, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Size = UDim2.new(0.75, 0, 0.75, 0)
        }):Play()
    end
end)

-- Thu gọn menu
closeBtn.MouseButton1Click:Connect(function()
    local tw = TweenService:Create(mainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
        Size = UDim2.new(0, 0, 0, 0)
    })
    tw:Play()
    tw.Completed:Connect(function()
        screenGuiMenu.Enabled = false
        pillButton.Visible = true
    end)
end)

-- Destroy menu
smallText.MouseButton1Click:Connect(function()
    local tw = TweenService:Create(mainFrame, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
        Size = UDim2.new(0, 0, 0, 0)
    })
    tw:Play()
    tw.Completed:Connect(function()
        screenGuiMenu:Destroy()
        toggleGui:Destroy()
    end)
end)

-- Chuyển ngôn ngữ
langText.MouseButton1Click:Connect(function()
    isEnglish = not isEnglish
    updateLanguage()
end)

-- Khởi tạo
updateLanguage()

-- =========================================
-- HIỆU ỨNG CHỮ CẢNH BÁO GIỮA MÀN HÌNH (Hiện 3s rồi mờ dần)
-- =========================================
local TweenService = game:GetService("TweenService")

if CoreGui:FindFirstChild("ArisFloatingWarning") then 
    CoreGui.ArisFloatingWarning:Destroy() 
end

local warningGui = Instance.new("ScreenGui")
warningGui.Name = "ArisFloatingWarning"
warningGui.Parent = CoreGui
warningGui.ResetOnSpawn = false

local floatingText = Instance.new("TextLabel")
floatingText.Size = UDim2.new(0, 600, 0, 60)
floatingText.Position = UDim2.new(0.5, 0, 0.25, 0)
floatingText.AnchorPoint = Vector2.new(0.5, 0.5)
floatingText.BackgroundTransparency = 1
floatingText.Font = Enum.Font.GothamBold
floatingText.TextSize = 22
floatingText.Text = "Mở \"READ ME\" để xem tác dụng và tác dụng phụ\nOpen \"READ ME\" to view effects and side effects"
floatingText.Parent = warningGui

local textStroke = Instance.new("UIStroke")
textStroke.Thickness = 1.5
textStroke.Color = Color3.fromRGB(255, 255, 255)
textStroke.Parent = floatingText

local floatGradient = Instance.new("UIGradient")
floatGradient.Color = ColorSequence.new({
    ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 0, 0)),
    ColorSequenceKeypoint.new(0.5, Color3.fromRGB(0, 0, 0)),
    ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 0, 0))
})
floatGradient.Parent = floatingText

-- Vòng lặp cho vệt màu chạy qua lại
local renderConnection
renderConnection = RunService.RenderStepped:Connect(function()
    floatGradient.Offset = Vector2.new((math.sin(tick() * 2) / 2), 0)
end)

-- Hiệu ứng chờ 3 giây rồi mờ dần từ từ
task.delay(3, function()
    -- Thời gian mờ dần là 1.5 giây (có thể chỉnh số 1.5 này nhanh/chậm tùy ý)
    local fadeInfo = TweenInfo.new(1.5, Enum.EasingStyle.Linear, Enum.EasingDirection.Out)
    
    local tweenText = TweenService:Create(floatingText, fadeInfo, {TextTransparency = 1})
    local tweenStroke = TweenService:Create(textStroke, fadeInfo, {Transparency = 1})
    
    tweenText:Play()
    tweenStroke:Play()
    
    -- Xóa GUI và ngắt vòng lặp màu khi đã mờ hẳn
    tweenText.Completed:Connect(function()
        if renderConnection then renderConnection:Disconnect() end
        warningGui:Destroy()
    end)
end)
