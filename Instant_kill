-- Logic Toggle
button.MouseButton1Click:Connect(function()
    local char = LocalPlayer.Character
    if not char then return end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not humanoid then return end

    -- Kiểm tra nếu chưa bật mà máu đã tụt xuống 20% hoặc thấp hơn thì từ chối bật
    if not onenabledshotho and humanoid.Health <= (humanoid.MaxHealth * 0.2) then
        return
    end

    onenabledshotho = not onenabledshotho
    
    -- Đổi trạng thái nền
    rainbowBG.Visible = onenabledshotho
    buttonFrame.BackgroundColor3 = onenabledshotho and Color3.new(1,1,1) or Color3.new(0,0,0)

    if onenabledshotho then
        task.spawn(function()
            while onenabledshotho do
                local currentHumanoid = char:FindFirstChildOfClass("Humanoid")
                
                -- Liên tục kiểm tra, nếu máu dưới hoặc bằng 20% thì tự động dừng
                if not currentHumanoid or currentHumanoid.Health <= (currentHumanoid.MaxHealth * 0.2) then
                    onenabledshotho = false
                    rainbowBG.Visible = false
                    buttonFrame.BackgroundColor3 = Color3.new(0,0,0)
                    break
                end
                
                local pos = hrp.Position
                hrp.CFrame = CFrame.new(pos.X, pos.Y - 999999999, pos.Z) -- Giữ nguyên logic hạ thấp tọa độ của bạn
                task.wait(0.01)
            end
        end)
    end
end)

