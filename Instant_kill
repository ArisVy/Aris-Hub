local function updateContent()
    -- Thêm đoạn hướng dẫn ở dòng đầu tiên
    local introText = isEnglish and 
        "Nhấn nút \"VI\" để chuyển sang tiếng Việt.\n» Press DESTROY to hide \"Read me\"\n\n" 
        or 
        "Press the \"EN\" button to switch to English.\n» Bấm DESTROY để ẩn \"Read me\"\n\n"

    local supportTitle = "★ Sword , Fruit support:"
    local noteTitle = isEnglish and "★ NOTE" or "★ LƯU Ý"
    
    local noteContent = isEnglish and 
        "# When you hit an enemy, turn it on immediately\n\n" ..
        "¿ For < Z > Spikey Trident, < F > Teti and Buddha: Hold until the enemy is defeated\n" ..
        "¿ For Saishi: Turn on and off immediately"
        or 
        "# Khi đánh dính vào kẻ địch thì bật ngay\n\n" ..
        "¿ Đối với <Z> Spikey Trident , <F> Yeti và Budha: giữ đến khi kẻ địch bị hạ\n" ..
        "¿ Đối với Saishi: Bật và tắt ngay lập tức"

    -- Thêm cảnh báo ở dòng cuối cùng
    local warningText = isEnglish and
        "⚠️ When using, your HP will decrease by a percentage. This is completely normal and cannot be prevented (it is a mandatory side effect) ⚠️"
        or
        "⚠️ Khi sử dụng Hp của bạn sẽ bị mất theo tỉ lệ % , đó là chuyện rất bình thường và không thể ngăn nó lại ( đó là tác dụng phụ bắt buộc ) ⚠️"

    -- Nối tất cả lại với nhau
    content.Text = introText .. 
                   supportTitle .. "\n\n" ..
                   "- F Budha,Yeti\n" ..
                   "- Z Saishi\n" ..
                   "- Z spikey Trident\n\n\n" ..
                   noteTitle .. "\n\n" .. noteContent .. "\n\n\n" .. 
                   warningText
end

local function updateLanguage()
    if isEnglish then
        menuTitle.Text = texts.en.title
        btnText.Text = texts.en.readMe
        smallText.Text = texts.en.destroy
        langText.Text = texts.en.langBtn
    else
        menuTitle.Text = texts.vi.title
        btnText.Text = texts.vi.readMe
        smallText.Text = texts.vi.destroy
        langText.Text = texts.vi.langBtn
    end
    updateContent()
end

